# ===========================================
# AI Conference System - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# These variables are used by application.properties via ${VAR:default} syntax.

# --- Server ---
SERVER_PORT=8080

# --- Database (PostgreSQL) ---
DB_URL=jdbc:postgresql://localhost:5432/ai_conference
DB_USERNAME=postgres
DB_PASSWORD=your_db_password_here

# --- Google Gemini AI ---
GOOGLE_AI_API_KEY=your_google_ai_api_key_here
GOOGLE_AI_MODEL=gemini-2.0-flash

# --- AI Feature Toggle ---
# Set to 'true' to use Gemini AI, 'false' to use keyword-based fallback
AI_ENABLED=true

# --- File Upload ---
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5MB
